# LLM — any OpenAI-SDK-compatible endpoint
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# Optional: faster model for adversary agents (falls back to LLM_* if blank)
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=

# Zep Cloud
ZEP_API_KEY=your-zep-api-key-here

# Flask
SECRET_KEY=change-this-in-production
FLASK_DEBUG=false
DRIFT_VERBOSE=false   # set to true for step-by-step simulation console logs
CORS_ORIGINS=http://localhost:3000

# Simulation
DEFAULT_MAX_ROUNDS=20
UPLOAD_FOLDER=uploads

# SQLite logging
SQLITE_DB_PATH=drift_logs.db
